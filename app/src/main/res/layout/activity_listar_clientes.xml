<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EDE8F5"
    tools:context=".ui.activity.ListarClientesActivity">

    <RelativeLayout
        android:id="@+id/lytHeaderList"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#5B4FFF"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Mis Clientes en SQLite"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvClientes"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="6dp"
        android:clipToPadding="false"
        app:layout_bottom_toTopOf="@id/btnSincronizarNube"
        app:layout_constraintTop_toBottomOf="@id/lytHeaderList" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSincronizarNube"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_margin="16dp"
        android:backgroundTint="#00C853"
        android:text="Sincronizar con Servidor Web"
        android:textAllCaps="false"
        android:textSize="15sp"
        android:textStyle="bold"
        app:icon="@android:drawable/stat_sys_upload"
        app:cornerRadius="14dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>